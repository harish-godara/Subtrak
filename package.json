{
  "name": "subtrack",
  "private": true,
  "version": "2.0.0",
  "description": "SubTrack — SaaS Subscription Manager (monorepo root)",
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w server",
    "build": "npm run build -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
